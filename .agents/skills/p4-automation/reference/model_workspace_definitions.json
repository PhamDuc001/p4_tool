    },
    "Readahead Libraries": {
      "required_branch_category": "System",
      "file_locations": [
        "device_common.mk",
        "Android.mk",
        "rscmgr.rc"
      ],
      "description": "Manage readahead libraries in rscmgr files"
    },
    "LoadApkAsset": {
      "required_branch_category": "System",
      "file_location": "ReadaheadManager.java",
      "description": "Manage Asset Apps for specific chipsets"
    }
  },
  "automation_rules": {
    "workspace_selection": {
      "default_branch_type": "REL",
      "branch_priority": ["REL", "FLUMEN", "BENI"]
    },
    "chipset_selection": {
      "default_to_primary": true,
      "fallback_to_alternatives": true
    }
  },
  "metadata": {
